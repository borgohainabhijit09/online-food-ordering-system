generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String    @id @default(uuid())
  slug           String    @unique
  businessName   String
  email          String    @unique
  phone          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  
  users          User[]
  categories     Category[]
  products       Product[]
  addons         Addon[]
  orders         Order[]
  settings       Settings?
  subscription   TenantSubscription?
  billingRecords BillingRecord[]
}

model User {
  id        String   @id @default(uuid())
  role      Role     @default(CUSTOMER)
  name      String
  phone     String   @unique
  password  String?
  orders    Order[]
  createdAt DateTime @default(now())

  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

enum DietaryPreference {
  VEG
  NON_VEG
  VEGAN
}

model Category {
  id        String    @id @default(uuid())
  name      String
  imageUrl  String?
  order     Int       @default(0)
  products  Product[]

  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
}

model Product {
  id          String    @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  offerPrice  Float?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  addons      ProductAddon[]
  inventory   Inventory?
  isActive    Boolean   @default(true)
  isTrending  Boolean   @default(false)
  dietaryPreference DietaryPreference @default(VEG)
  isSpicy     Boolean   @default(false)

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(uuid())
  name      String
  price     Float
  offerPrice Float?
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Addon {
  id            String         @id @default(uuid())
  name          String
  price         Float
  imageUrl      String?
  productAddons ProductAddon[]

  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
}

model ProductAddon {
  productId String
  addonId   String
  product   Product @relation(fields: [productId], references: [id])
  addon     Addon   @relation(fields: [addonId], references: [id])
  @@id([productId, addonId])
}

model Inventory {
  id           String  @id @default(uuid())
  productId    String  @unique
  product      Product @relation(fields: [productId], references: [id])
  currentStock Int     @default(0)
  minimumStock Int     @default(5)
}

model Order {
  id               String      @id @default(uuid())
  userId           String?
  user             User?       @relation(fields: [userId], references: [id])
  customerName     String
  phone            String
  address          String
  latitude         Float
  longitude        Float
  status           OrderStatus @default(NEW)
  total            Float
  remarks          String?
  items            OrderItem[]
  createdAt        DateTime    @default(now())

  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
}

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String          @id @default(uuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id])
  productId String
  quantity  Int
  price     Float
  variant   String?
  addons    OrderItemAddon[]
}

model OrderItemAddon {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  addonName   String
  price       Float
}

model Settings {
  id                 String  @id @default(uuid())
  restaurantName     String
  isAcceptingOrders  Boolean @default(true)
  deliveryRadiusKm   Float   @default(5.0)
  restaurantLat      Float
  restaurantLng      Float
  whatsappNumber     String

  tenantId           String  @unique
  tenant             Tenant  @relation(fields: [tenantId], references: [id])
}

model SubscriptionPackage {
  id          String   @id @default(uuid())
  name        String   @unique
  price       Float
  features    String
  createdAt   DateTime @default(now())

  tenants     TenantSubscription[]
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

model TenantSubscription {
  id              String             @id @default(uuid())
  tenantId        String             @unique
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  packageId       String
  package         SubscriptionPackage @relation(fields: [packageId], references: [id])
  startDate       DateTime           @default(now())
  nextBillingDate DateTime
  status          SubscriptionStatus @default(ACTIVE)
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model BillingRecord {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  amount      Float
  date        DateTime      @default(now())
  status      PaymentStatus @default(COMPLETED)
  invoiceUrl  String?
}

