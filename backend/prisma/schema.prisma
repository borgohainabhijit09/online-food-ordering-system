generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String   @id @default(uuid())
  slug         String   @unique
  businessName String
  email        String   @unique
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  users          User[]
  categories     Category[]
  products       Product[]
  addons         Addon[]
  orders         Order[]
  tables         RestaurantTable[]
  events         RestaurantEvent[]
  settings       Settings?
  subscription   TenantSubscription?
  billingRecords BillingRecord[]
  coupons        Coupon[]
  customers      Customer[]
}

model User {
  id        String   @id @default(uuid())
  role      Role     @default(CUSTOMER)
  name      String
  phone     String   @unique
  password  String?
  orders    Order[]
  createdAt DateTime @default(now())

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  lastLoginAt DateTime?
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

enum DietaryPreference {
  VEG
  NON_VEG
  VEGAN
}

model Category {
  id       String    @id @default(uuid())
  name     String
  imageUrl String?
  order    Int       @default(0)
  isActive Boolean   @default(true)
  products Product[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model Product {
  id                String            @id @default(uuid())
  name              String
  description       String?
  basePrice         Float
  offerPrice        Float?
  categoryId        String
  category          Category          @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  variants          ProductVariant[]
  addons            ProductAddon[]
  inventory         Inventory?
  isActive          Boolean           @default(true)
  isTrending        Boolean           @default(false)
  dietaryPreference DietaryPreference @default(VEG)
  isSpicy           Boolean           @default(false)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id         String  @id @default(uuid())
  name       String
  price      Float
  offerPrice Float?
  productId  String
  product    Product @relation(fields: [productId], references: [id])
}

model Addon {
  id            String         @id @default(uuid())
  name          String
  price         Float
  imageUrl      String?
  productAddons ProductAddon[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model ProductAddon {
  productId String
  addonId   String
  product   Product @relation(fields: [productId], references: [id])
  addon     Addon   @relation(fields: [addonId], references: [id])

  @@id([productId, addonId])
}

model Inventory {
  id           String  @id @default(uuid())
  productId    String  @unique
  product      Product @relation(fields: [productId], references: [id])
  currentStock Int     @default(0)
  minimumStock Int     @default(5)
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  phone     String
  dob       DateTime?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, phone])
}

model Order {
  id             String      @id @default(uuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  customerName   String
  phone          String
  orderType      OrderType   @default(DELIVERY)
  address        String?
  latitude       Float?
  longitude      Float?
  tableId        String?
  table          RestaurantTable? @relation(fields: [tableId], references: [id])
  status         OrderStatus @default(NEW)
  total          Float
  remarks        String?
  items          OrderItem[]
  couponCode     String?
  discountAmount Float?      @default(0)
  createdAt      DateTime    @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

enum OrderType {
  DELIVERY
  TAKEAWAY
  DINE_IN
}

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String           @id @default(uuid())
  orderId   String
  order     Order            @relation(fields: [orderId], references: [id])
  productId String
  quantity  Int
  price     Float
  variant   String?
  addons    OrderItemAddon[]
}

model OrderItemAddon {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  addonName   String
  price       Float
}

model Settings {
  id                String  @id @default(uuid())
  restaurantName    String
  isAcceptingOrders Boolean @default(true)
  deliveryRadiusKm  Float   @default(5.0)
  restaurantLat        Float
  restaurantLng        Float
  whatsappNumber       String
  hasDeliveryCharge    Boolean @default(false)
  deliveryChargeAmount Float   @default(0)
  logoUrl              String?
  fssaiNumber          String?

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model SubscriptionPackage {
  id        String   @id @default(uuid())
  name      String   @unique
  price     Float
  features  String
  createdAt DateTime @default(now())

  tenants TenantSubscription[]
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
}

model TenantSubscription {
  id              String              @id @default(uuid())
  tenantId        String              @unique
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  packageId       String
  package         SubscriptionPackage @relation(fields: [packageId], references: [id])
  startDate       DateTime            @default(now())
  nextBillingDate DateTime
  status          SubscriptionStatus  @default(ACTIVE)
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model BillingRecord {
  id         String        @id @default(uuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  amount     Float
  date       DateTime      @default(now())
  status     PaymentStatus @default(COMPLETED)
  invoiceUrl String?
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

model Coupon {
  id             String       @id @default(uuid())
  tenantId       String
  code           String
  discountType   DiscountType
  discountValue  Float
  minOrderValue  Float?
  maxDiscount    Float?
  firstOrderOnly Boolean      @default(false)
  active         Boolean      @default(true)
  startDate      DateTime?
  expiryDate     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RestaurantTable {
  id           String      @id @default(uuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  tableNumber  String
  tableName    String?
  capacity     Int         @default(4)
  status       TableStatus @default(AVAILABLE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  orders       Order[]
  events       RestaurantEvent[]

  @@unique([tenantId, tableNumber])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

model RestaurantEvent {
  id           String      @id @default(uuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  tableId      String
  table        RestaurantTable @relation(fields: [tableId], references: [id])
  type         EventType
  status       EventStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  resolvedAt   DateTime?
}

enum EventType {
  CALL_WAITER
  REQUEST_BILL
}

enum EventStatus {
  PENDING
  RESOLVED
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  TRIAL_STARTED
  PAID_CUSTOMER
  LOST
}

model Lead {
  id               String     @id @default(uuid())
  restaurantName   String
  ownerName        String
  phone            String
  email            String?
  city             String?
  source           String?
  assignedTo       String?
  status           LeadStatus @default(NEW)
  notes            String?
  nextFollowUpDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}
